# Port the server listens on (Render sets this automatically).
PORT=3000

# MongoDB connection string.
#   Local dev:   mongodb://127.0.0.1:27017
#   Production:  MongoDB Atlas SRV URI, e.g.
#                mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net
MONGODB_URI=mongodb://127.0.0.1:27017

# Database name (collections are created automatically).
DB_NAME=next-imaginations

# Long random secret. Required for GET /api/enquiries and PATCH status.
# Generate one:  node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
ADMIN_TOKEN=replace-with-a-long-random-string

# Comma-separated list of sites allowed to call this API.
# Vercel preview URLs (*.vercel.app) are allowed automatically.
ALLOWED_ORIGINS=https://nextimaginations.com,https://www.nextimaginations.com

# --- Email automation (already working in production via Brevo) ---
# BREVO_API_KEY=xkeysib-...        # Brevo HTTPS API key (Render free tier blocks SMTP ports)
# NOTIFY_EMAIL=nextimaginations@gmail.com   # where new-lead alerts are sent

# --- Optional: WhatsApp owner alerts (Meta Cloud API). Dormant until all 3 set ---
# WHATSAPP_TOKEN=            # permanent access token from Meta
# WHATSAPP_PHONE_ID=         # WhatsApp phone number ID
# OWNER_WHATSAPP=9189300006242   # your number in international format, digits only
# WHATSAPP_TEMPLATE=         # optional approved template name for business-initiated msgs
